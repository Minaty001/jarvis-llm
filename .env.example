# ────────────────────────────────────────────
# JARVIS Backend - Environment Configuration
# Copy to .env and fill in your values
# ────────────────────────────────────────────

# ── App Identity ──
APP_NAME=jarvis-backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── Server ──
PORT=8000
HOST=0.0.0.0
WORKERS=4

# ── Security ──
JWT_SECRET=change-me-to-a-min-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7

# ── External Services ──
# REQUIRED: Set this to your Brain service URL on Render.com
# e.g. https://jarvis-brain.onrender.com
BRAIN_URL=https://your-brain-service.onrender.com
BRAIN_TIMEOUT=30
LLM_URL=http://localhost:8002
LLM_TIMEOUT=60
SKILL_URL=http://localhost:8003
SKILL_TIMEOUT=120

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── Logging ──
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ── Optional: Redis ──
# REDIS_URL=redis://localhost:6379

# ── Optional: Telegram Alerts ──
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
